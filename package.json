{
  "name": "cclens",
  "version": "0.1.0",
  "description": "A visual dashboard for Claude Code — browse and edit agents, commands, skills, and workflows without touching config files.",
  "type": "module",
  "bin": {
    "cclens": "./bin/start.mjs"
  },
  "files": [
    "bin/",
    ".output/"
  ],
  "scripts": {
    "build": "nuxt build && node -e \"import('node:fs').then(fs => fs.rmSync('.output/server/node_modules/node-pty', {recursive:true, force:true}))\"",
    "prepublishOnly": "nuxt build && node -e \"import('node:fs').then(fs => fs.rmSync('.output/server/node_modules/node-pty', {recursive:true, force:true}))\"",
    "dev": "nuxt dev --port 3030",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.191",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nuxt/ui": "^3",
    "@vue-flow/controls": "^1.1",
    "@vue-flow/core": "^1.41",
    "@vue-flow/minimap": "^1.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "nuxt": "^3.16",
    "shiki": "^4.0.2",
    "ws": "^8.20.0",
    "yaml": "^2.6"
  },
  "devDependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@iconify-json/lucide": "^1.2.95",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qingwave/claude-code-lens.git"
  },
  "homepage": "https://github.com/qingwave/claude-code-lens",
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "dashboard",
    "ui",
    "nuxt"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14"
}
